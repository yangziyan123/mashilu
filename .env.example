PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional emergency rollback path. Leave unset or false for normal phase 1 builds.
SUPABASE_FALLBACK_TO_MARKDOWN=false

# Optional, only for local one-off import scripts.
# Never expose this in PUBLIC_ variables, frontend code, or GitHub Pages builds.
SUPABASE_SERVICE_ROLE_KEY=
