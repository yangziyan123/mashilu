---
import BaseLayout from "./BaseLayout.astro";
import Badge from "@/components/Badge.astro";
import InfoBlock from "@/components/InfoBlock.astro";
import InfoText from "@/components/InfoText.astro";
import IpCard from "@/components/IpCard.astro";
import type { IpEntry } from "@/lib/ips";
import { getIpDescription, getCategorySlug, getImageSrc, getLinkHost } from "@/lib/ips";
import { withBase } from "@/lib/url";

interface Props {
  ip: IpEntry;
  related: IpEntry[];
}

const { ip, related } = Astro.props;
const data = ip.data;
const description = getIpDescription(ip);
const imageSrc = getImageSrc(ip);
const displayImageSrc = imageSrc.startsWith("/") ? withBase(imageSrc) : imageSrc;
const primaryLink = data.productLinks[0];
---

<BaseLayout title={`${data.name} ${data.owner} - ${data.primaryDirection} | 码师录`} description={description}>
  <article class="site-shell py-8">
    <div class="mb-6 text-sm">
      <a class="font-semibold text-brand hover:underline" href={withBase("/ips/")}>IP 库</a>
      <span class="mx-2 text-muted">/</span>
      <span class="text-muted">{data.name}</span>
    </div>

    <header class="rounded-lg border border-line bg-white p-5 shadow-sm md:p-6">
      <div class="grid gap-5 lg:grid-cols-[1fr_280px]">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
          <img
            class="h-24 w-24 shrink-0 rounded-lg border border-line bg-panel object-cover"
            src={displayImageSrc}
            alt={data.image.alt}
            loading="eager"
            decoding="async"
          />
          <div class="min-w-0">
            <div class="flex flex-wrap gap-2">
              <Badge tone="status">{data.dataStatus}</Badge>
              {data.categories.map((category) => (
                <a
                  class="rounded-md border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-bold text-slate-700 hover:border-brand hover:text-brand"
                  href={withBase(`/categories/${getCategorySlug(category)}/`)}
                >
                  {category}
                </a>
              ))}
            </div>
            <h1 class="mt-4 text-3xl font-black tracking-normal text-ink md:text-4xl">{data.name}</h1>
            <p class="mt-3 max-w-3xl text-base leading-7 text-muted">{description}</p>
            <p class="mt-3 text-xs font-semibold text-slate-500">
              图片来源：{data.image.source ?? "本地整理"}
            </p>
          </div>
        </div>
        <div class="rounded-lg border border-line bg-panel p-4">
          <dl class="grid gap-3 text-sm">
            <div>
              <dt class="font-bold text-slate-900">主理人</dt>
              <dd class="mt-1 text-muted">{data.owner}</dd>
            </div>
            <div>
              <dt class="font-bold text-slate-900">首要入口</dt>
              <dd class="mt-1">
                <a class="font-semibold text-brand hover:underline" href={primaryLink.url}>{primaryLink.label}</a>
                <span class="mt-1 block break-all text-xs text-muted">{getLinkHost(primaryLink)}</span>
              </dd>
            </div>
            <div>
              <dt class="font-bold text-slate-900">入口数量</dt>
              <dd class="mt-1 text-muted">{data.productLinks.length} 个已收录入口</dd>
            </div>
            <div>
              <dt class="font-bold text-slate-900">最近核验</dt>
              <dd class="mt-1 text-muted">{data.lastVerified}</dd>
            </div>
          </dl>
        </div>
      </div>
    </header>

    <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_320px]">
      <div class="rounded-lg border border-line bg-white p-5 shadow-sm md:p-6">
        <section class="grid gap-4 md:grid-cols-2">
          <InfoBlock title="内容形态" items={data.contentTypes} />
          <InfoBlock title="适合人群" items={data.suitableFor} />
          <InfoText title="免费资源" text={data.freeResources} />
          <InfoText title="付费产品" text={data.paidProducts} />
          <InfoText title="推荐使用场景" text={data.recommendedUseCase} />
          <InfoText title="注意点/潜在风险" text={data.riskNotes} tone="risk" />
        </section>

        <section class="content-body mt-8 border-t border-line pt-6" data-pagefind-body>
          <slot />
        </section>
      </div>

      <aside class="space-y-6">
        <section class="rounded-lg border border-line bg-white p-5 shadow-sm">
          <h2 class="text-lg font-extrabold text-ink">产品/平台入口</h2>
          <ul class="mt-3 grid gap-3 text-sm">
            {
              data.productLinks.map((link) => (
                <li class="rounded-lg border border-line bg-panel p-3">
                  <div class="flex items-center justify-between gap-2">
                    <span class="rounded-md bg-white px-2 py-1 text-xs font-bold text-slate-700">{link.type}</span>
                    {link.note && <span class="text-xs font-semibold text-muted">{link.note}</span>}
                  </div>
                  <a class="mt-2 block font-bold text-brand hover:underline" href={link.url}>{link.label}</a>
                  <span class="mt-1 block break-all text-xs text-muted">{getLinkHost(link)}</span>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="rounded-lg border border-line bg-white p-5 shadow-sm">
          <h2 class="text-lg font-extrabold text-ink">标签</h2>
          <div class="mt-3 flex flex-wrap gap-2">
            {data.tags.map((tag) => <Badge>{tag}</Badge>)}
          </div>
        </section>

        <section class="rounded-lg border border-line bg-white p-5 shadow-sm">
          <h2 class="text-lg font-extrabold text-ink">来源</h2>
          <ul class="mt-3 grid gap-2 text-sm">
            {
              data.sources.map((source) => (
                <li>
                  <a class="break-all font-semibold text-brand hover:underline" href={source}>{source}</a>
                </li>
              ))
            }
          </ul>
        </section>
      </aside>
    </div>

    {
      related.length > 0 && (
        <section class="mt-8">
          <h2 class="text-xl font-extrabold text-ink">同类 IP</h2>
          <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            {related.map((item) => <IpCard ip={item} />)}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>
