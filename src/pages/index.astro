---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CategoryFilter from "@/components/CategoryFilter.astro";
import IpCard from "@/components/IpCard.astro";
import SearchBox from "@/components/SearchBox.astro";
import Stat from "@/components/Stat.astro";
import { site } from "@/data/site";
import { getAllIps } from "@/lib/ip-repository";
import { getAllTags, getCategoryStats, sortIps } from "@/lib/ips";
import { withBase } from "@/lib/url";

const ips = sortIps(await getAllIps());
const categories = getCategoryStats(ips);
const tags = getAllTags(ips);
const latest = [...ips]
  .sort((a, b) => b.data.lastVerified.localeCompare(a.data.lastVerified))
  .slice(0, 8);
const pendingCount = ips.filter((ip) => ip.data.dataStatus === "待核验").length;
---

<BaseLayout>
  <section class="border-b border-line bg-white">
    <div class="site-shell grid gap-6 py-8 lg:grid-cols-[minmax(0,1fr)_320px]">
      <div>
        <h1 class="max-w-3xl text-3xl font-black tracking-normal text-ink md:text-5xl">
          {site.name}
        </h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-muted md:text-lg">
          面向计算机学习者的个人 IP 教学资源索引库，优先回答“是谁、适合谁、免费与付费边界、注意点是什么”。
        </p>
        <div class="mt-5 max-w-3xl">
          <SearchBox />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3 rounded-lg border border-line bg-panel p-4">
        <Stat label="收录 IP" value={ips.length} />
        <Stat label="一级分类" value={categories.length} />
        <Stat label="内容标签" value={tags.length} />
        <Stat label="待核验" value={pendingCount} />
      </div>
    </div>
  </section>

  <section class="site-shell py-8">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="text-xl font-extrabold text-ink">分类入口</h2>
        <p class="mt-1 text-sm text-muted">按学习方向进入对应 IP 池。</p>
      </div>
      <a class="text-sm font-bold text-brand hover:underline" href={withBase("/ips/")}>查看全部</a>
    </div>
    <div class="mt-4">
      <CategoryFilter categories={categories} />
    </div>
  </section>

  <section class="site-shell py-8">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="text-xl font-extrabold text-ink">最新收录</h2>
        <p class="mt-1 text-sm text-muted">按最近核验日期展示。</p>
      </div>
      <a class="text-sm font-bold text-brand hover:underline" href={withBase("/submit/")}>推荐新 IP</a>
    </div>
    <div class="mt-4 overflow-x-auto rounded-lg border border-line bg-white shadow-sm">
      <table class="w-full min-w-[640px] text-left text-sm">
        <thead class="bg-panel text-xs font-bold uppercase text-slate-600">
          <tr>
            <th class="px-4 py-3">名称</th>
            <th class="px-4 py-3">主方向</th>
            <th class="px-4 py-3">状态</th>
            <th class="px-4 py-3">核验日期</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line">
          {
            latest.map((ip) => (
              <tr>
                <td class="px-4 py-3">
                  <a class="font-bold text-ink hover:text-brand hover:underline" href={withBase(`/ips/${ip.data.slug}/`)}>
                    {ip.data.name}
                  </a>
                </td>
                <td class="px-4 py-3 text-muted">{ip.data.primaryDirection}</td>
                <td class="px-4 py-3 text-muted">{ip.data.dataStatus}</td>
                <td class="px-4 py-3 text-muted">{ip.data.lastVerified}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
