---
import { marked } from "marked";
import IpLayout from "@/layouts/IpLayout.astro";
import { getAllIps } from "@/lib/ip-repository";
import { getRelatedIps, sortIps } from "@/lib/ips";

export async function getStaticPaths() {
  const ips = sortIps(await getAllIps());
  return ips.map((ip) => ({
    params: { slug: ip.data.slug },
    props: {
      ip,
      related: getRelatedIps(ip, ips),
    },
  }));
}

const { ip, related } = Astro.props;
const bodyHtml = await marked.parse(ip.bodyMarkdown ?? ip.body ?? "");
---

<IpLayout ip={ip} related={related}>
  <Fragment set:html={bodyHtml} />
</IpLayout>
