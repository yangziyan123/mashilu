---
interface Props {
  tone?: "status" | "neutral" | "risk";
}

const { tone = "neutral" } = Astro.props;
const classes = {
  status: "border-teal-200 bg-teal-50 text-teal-800",
  neutral: "border-slate-200 bg-slate-50 text-slate-700",
  risk: "border-rose-200 bg-rose-50 text-rose-800",
};
---

<span class={`inline-flex items-center rounded-md border px-2 py-1 text-xs font-bold ${classes[tone]}`}>
  <slot />
</span>
