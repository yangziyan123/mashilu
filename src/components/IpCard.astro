---
import type { IpEntry } from "@/lib/ips";
import { getCategorySlug, getImageSrc } from "@/lib/ips";
import { withBase } from "@/lib/url";
import Badge from "./Badge.astro";

interface Props {
  ip: IpEntry;
}

const { ip } = Astro.props;
const data = ip.data;
const imageSrc = getImageSrc(ip);
const displayImageSrc = imageSrc.startsWith("/") ? withBase(imageSrc) : imageSrc;
const visibleLinks = data.productLinks.slice(0, 3);
---

<article
  class="ip-card rounded-lg border border-line bg-white p-4 shadow-sm"
  data-name={data.name}
  data-owner={data.owner}
  data-category={data.categories.join(" ")}
  data-tags={data.tags.join(" ")}
  data-links={data.productLinks.map((link) => `${link.type} ${link.label} ${link.url}`).join(" ")}
  data-status={data.dataStatus}
>
  <div class="flex items-start gap-3">
    <img
      class="h-14 w-14 shrink-0 rounded-lg border border-line bg-panel object-cover"
      src={displayImageSrc}
      alt={data.image.alt}
      loading="lazy"
      decoding="async"
    />
    <div class="min-w-0">
      <a class="text-lg font-extrabold text-ink hover:text-brand hover:underline" href={withBase(`/ips/${data.slug}/`)}>
        {data.name}
      </a>
      <p class="mt-1 text-sm text-muted">{data.owner} · {data.type}</p>
      <p class="mt-1 text-xs font-semibold text-slate-500">已收录 {data.productLinks.length} 个入口</p>
    </div>
  </div>

  <div class="mt-3 flex flex-wrap gap-2">
    {
      data.categories.map((category) => (
        <a
          class="rounded-md border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-bold text-slate-700 hover:border-brand hover:text-brand"
          href={withBase(`/categories/${getCategorySlug(category)}/`)}
        >
          {category}
        </a>
      ))
    }
    <Badge tone="status">{data.dataStatus}</Badge>
  </div>

  <dl class="mt-4 grid gap-3 text-sm">
    <div>
      <dt class="font-bold text-slate-900">主方向</dt>
      <dd class="mt-1 text-muted">{data.primaryDirection}</dd>
    </div>
    <div>
      <dt class="font-bold text-slate-900">适合人群</dt>
      <dd class="mt-1 text-muted">{data.suitableFor.join("、")}</dd>
    </div>
    <div>
      <dt class="font-bold text-slate-900">推荐场景</dt>
      <dd class="mt-1 text-muted">{data.recommendedUseCase}</dd>
    </div>
  </dl>

  <div class="mt-4 border-t border-line pt-4 text-sm">
    <p class="line-clamp-2 text-muted"><strong class="text-ink">免费：</strong>{data.freeResources}</p>
    <p class="mt-2 line-clamp-2 text-muted"><strong class="text-ink">付费：</strong>{data.paidProducts}</p>
    <div class="mt-3 flex flex-wrap gap-2">
      {
        visibleLinks.map((link) => (
          <a
            class="rounded-md border border-line px-2 py-1 text-xs font-bold text-slate-700 hover:border-brand hover:text-brand"
            href={link.url}
          >
            {link.type}
          </a>
        ))
      }
    </div>
  </div>
</article>
